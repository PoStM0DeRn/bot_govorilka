# Пример .env файла для голосового ассистента
# Скопируйте в .env и настройте под свою систему

# === Whisper (STT) ===
WHISPER_MODEL=small            # tiny/base/small/medium/large-v3/turbo
WHISPER_LANGUAGE=ru            # None = авто-определение языка
# WHISPER_DEVICE=cuda          # cuda/cpu, None = auto
# WHISPER_COMPUTE_TYPE=float16 # float16(int8 для CPU), None = auto

# === VAD (Voice Activity Detection) ===
VAD_THRESHOLD=0.5              # Порог детекции речи (0.0-1.0)
VAD_SILENCE_TIMEOUT_MS=600     # Тишина дольше (мс) → конец фразы
VAD_SPEECH_PAD_MS=200          # Паддинг вокруг речи (мс)
VAD_MIN_SPEECH_MS=100          # Минимальная длительность речи (мс)

# === Wake Word ===
WAKE_WORD_ENABLED=true        # Включить режим wake word
WAKE_WORD_MODEL=alexa     # Модель wake word (hey_jarvis, alexa, и т.д.)
WAKE_WORD_THRESHOLD=0.5        # Порог детекции wake word

# === LM Studio (LLM) ===
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=              # Имя модели в LM Studio (пусто = default)

# === Silero TTS ===
TTS_SPEAKER=kseniya           # Голос: kseniya, baya, xenia, aidar, eugene
TTS_SAMPLE_RATE=48000         # Частота дискретизации

# === Системный промпт ===
# SYSTEM_PROMPT=Ты — голосовой ассистент...

# === История ===
MAX_HISTORY=20                 # Максимум сообщений в истории
HISTORY_FILE=history.json      # Путь к файлу истории

# === Аватар ===
AVATAR_MODEL_PATH=Resources/Kei/kei_vowels_pro/runtime/kei_vowels_pro.model3.json
AVATAR_WIDTH=500
AVATAR_HEIGHT=600
AVATAR_LIP_SYNC_MULT=3.0
# AVATAR_BACKGROUND=path/to/bg.png

# === Прочее ===
MAX_INPUT_LENGTH=500           # Максимальная длина пользовательского ввода
MAX_AUDIO_SECONDS=60           # Максимальная длительность записи (сек)
